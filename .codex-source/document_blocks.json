  {
    "type": "paragraph",
    "index": 70,
    "style": "List Bullet",
    "text": "🌄 Tagaytay Ridge Hike Scenic trail with Taal volcano views"
  },
  {
    "type": "paragraph",
    "index": 71,
    "style": "List Bullet",
    "text": "🔥 Barkada Hillside Firepit Kwentuhan & cool Cavite nights"
  },
  {
    "type": "paragraph",
    "index": 72,
    "style": "List Bullet",
    "text": "⭐ Stargazing Nights No light pollution — just pure sky"
  },
  {
    "type": "paragraph",
    "index": 73,
